# ==========================================
# Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
.venv/
venv/
env/
ENV/

# ==========================================
# IDE
# ==========================================
.vscode/
.idea/

# ==========================================
# Operating System
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Logs
# ==========================================
logs/*.log
*.log

# Keep the logs folder
!logs/.gitkeep

# ==========================================
# SQLite Database
# ==========================================
data/*.db
*.db

# ==========================================
# Output Files
# ==========================================
output/*.csv
output/*.xlsx
output/*.json

# Keep the output folder
!output/.gitkeep

# ==========================================
# Temporary Files
# ==========================================
*.tmp
*.bak
*.swp

# ==========================================
# Environment Variables
# ==========================================
.env

# ==========================================
# Playwright
# ==========================================
playwright/.cache/

# ==========================================
